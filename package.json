{
  "name": "@arki/dot",
  "version": "0.4.0",
  "description": "TypeScript-first application composition framework for the ARKI package family — lifecycle-aware plugins, deterministic boot order, manifest/diagnostics envelopes, and an agent-native CLI. A DOT app is the sum of its plugins.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arki-labs/arki.git"
  },
  "homepage": "https://arki.dev/dot",
  "bugs": {
    "url": "https://github.com/arki-labs/arki/issues"
  },
  "keywords": [
    "arki",
    "typescript",
    "framework",
    "plugin",
    "plugins",
    "lifecycle",
    "diagnostics",
    "manifest",
    "agent-native",
    "dot"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./package.json": "./package.json",
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./src/cli/index.ts",
      "default": "./dist/cli/index.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness.d.ts",
      "import": "./src/test-harness.ts",
      "default": "./dist/test-harness.js"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/tests/**",
    "!src/**/test/**",
    "!src/**/__tests__/**",
    "templates/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "@arki/assert": "0.0.2",
    "@arki/contracts": "0.0.3",
    "@arki/log": "0.0.2",
    "@opentelemetry/api": "^1.9.0",
    "zod": "4.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
